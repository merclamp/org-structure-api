# Copy this file to `.env` and adjust as needed.
# docker-compose reads `.env` automatically for variable substitution.

# --- Application ---
DEBUG=false
LOG_LEVEL=INFO

# --- PostgreSQL ---
# Inside docker-compose use POSTGRES_HOST=db.
# For running the app locally against the exposed container use localhost.
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=org_structure
